# App
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# Security / identity (mock for local dev)
JWT_ISSUER=https://example-issuer
JWT_AUDIENCE=secure-health-rag
JWT_JWKS_URL=https://example-issuer/.well-known/jwks.json
REQUIRE_SCOPES=reports:read

# Multi-tenant defaults for local testing
DEFAULT_TENANT_ID=tenant-demo
DEFAULT_PATIENT_ID=patient-demo

# Model + guardrails (placeholders)
MODEL_PROVIDER=bedrock
MODEL_ID=[BEDROCK_MODEL_ID]
GUARDRAIL_ID=[BEDROCK_GUARDRAIL_ID]
GUARDRAIL_VERSION=1
AWS_REGION=eu-central-1

# Storage placeholders
STRUCTURED_DB_URL=sqlite:///./data/structured.db
VECTOR_STORE_URL=sqlite:///./data/vectors.db

# Secrets placeholders (never commit real values)
AWS_ACCESS_KEY_ID=[AWS_ACCESS_KEY_ID]
AWS_SECRET_ACCESS_KEY=[AWS_SECRET_ACCESS_KEY]
AWS_SESSION_TOKEN=[AWS_SESSION_TOKEN]
KMS_KEY_ARN=[KMS_KEY_ARN]

# Optional redaction backends
PRESIDIO_ENABLED=true
COMPREHEND_MEDICAL_ENABLED=false

# Observability
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=[OTEL_ENDPOINT]

# Copy to .env before first run.

# ------------------------------------------------------------------------------
# Core database
# ------------------------------------------------------------------------------
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=mission_control
POSTGRES_USER=mission_control_app
POSTGRES_PASSWORD=change_this_now
POSTGRES_PORT=5432

# Separate database/user for Metabase application metadata
METABASE_APP_DB=metabase_app
METABASE_APP_DB_USER=metabase_app
METABASE_APP_DB_PASSWORD=change_this_now_too

# ------------------------------------------------------------------------------
# Appsmith
# ------------------------------------------------------------------------------
APPSMITH_IMAGE=appsmith/appsmith-ce
APPSMITH_PORT=8080

# ------------------------------------------------------------------------------
# Metabase
# ------------------------------------------------------------------------------
METABASE_IMAGE=metabase/metabase:latest
METABASE_PORT=3000
MB_ENCRYPTION_SECRET_KEY=replace_with_a_32_plus_char_secret

# ------------------------------------------------------------------------------
# Optional project metadata
# ------------------------------------------------------------------------------
MC_ENVIRONMENT=local
MC_SITE_NAME=Mission Control
MC_PUBLIC_BASE_URL=http://localhost

# ------------------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------------------
# For serious internal production use:
# - pin exact image digests
# - move secrets out of .env
# - front the services with TLS
# - restrict access at the network layer
